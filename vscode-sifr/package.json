{
  "name": "sifr-lang",
  "displayName": "Sifr — لغة صِفر العربية",
  "description": "Syntax highlighting, snippets, and full language reference for Sifr (صِفر), the Arabic-first programming language.",
  "version": "1.1.0",
  "publisher": "sifr-lang",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Snippets"],
  "keywords": ["arabic", "sifr", "صفر", "عربي", "rtl"],
  "contributes": {
    "languages": [{
      "id": "sifr",
      "aliases": ["Sifr", "صِفر", "صفر", "Arabica"],
      "extensions": [".sifr", ".صفر", ".arb"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "sifr",
      "scopeName": "source.sifr",
      "path": "./syntaxes/sifr.tmLanguage.json"
    }],
    "snippets": [{
      "language": "sifr",
      "path": "./snippets/sifr.json"
    }]
  },
  "repository": { "type": "git", "url": "https://github.com/sifr-lang/sifr" },
  "license": "MIT"
}
