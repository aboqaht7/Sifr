{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sifr",
  "scopeName": "source.sifr",
  "fileTypes": ["sifr", "氐賮乇", "arb"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.sifr", "match": "//.*$" },
        { "name": "comment.block.sifr", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sifr",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.sifr", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.single.sifr",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.sifr", "match": "\\\\." }]
        },
        {
          "name": "string.template.sifr",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.embedded.expression.sifr",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            },
            { "name": "constant.character.escape.sifr", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.sifr", "match": "\\b\\d+(\\.\\d+)?\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sifr",
          "match": "(?<![\\u0600-\\u06FF_\\w])(廿賳|賵廿賱丕|賰乇乇|噩賵丕賱|賮賷|賲賳|廿賱賶|亘禺胤賵丞|兀毓丿|鬲賵賯賮|鬲丕亘毓|胤丕亘賯|丨丕賱|丨丕賵賱|丕賱鬲賯胤|兀禺賷乇丕賸|禺胤兀|丕賳鬲賴賶)(?![\\u0600-\\u06FF_\\w])"
        },
        {
          "name": "keyword.declaration.sifr",
          "match": "(?<![\\u0600-\\u06FF_\\w])(賰賳夭|爻乇賾|賲賴賲賾丞|亘賳賷丞|賵丕乇孬|賷乇孬|賵丨丿丞|氐丿賾乇|丕爻鬲賵乇丿|丕禺鬲亘乇)(?![\\u0600-\\u06FF_\\w])"
        },
        {
          "name": "keyword.other.sifr",
          "match": "(?<![\\u0600-\\u06FF_\\w])(賴匕丕|廿囟丕賮丞|丨匕賮)(?![\\u0600-\\u06FF_\\w])"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.sifr",
          "match": "(?<![\\u0600-\\u06FF_\\w])(氐丿賯|賰匕亘|毓丿賲)(?![\\u0600-\\u06FF_\\w])"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.sifr",
          "match": "(?<=:\\s*)(乇賯賲|賳氐|賲賳胤賯賷|賯丕卅賲丞|賰丕卅賳|丿丕賱丞|毓丿賲|兀賷)(?![\\u0600-\\u06FF_\\w])"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.sifr",
          "match": "(?<![\\u0600-\\u06FF_\\w])(兀乇賳賷|賳氐|毓丿丿|噩匕乇|賲胤賱賯|丿賵乇|爻賯賮|兀乇囟|兀賯氐賶|兀丿賳賶|毓卮賵丕卅賷|禺乇賷胤丞|鬲氐賮賷丞|丕禺鬲夭丕賱|賮乇夭|毓賰爻|卮乇賷丨丞|胤賵賱|丕賱丌賳|爻賳丞|卮賴乇|賷賵賲|噩賱亘|丕丨賮馗_賲賱賮|丕丨賮馗|丨賲賾賱|廿賱賶_噩爻賵賳|賲賳_噩爻賵賳|賳賲胤|鬲賵賯賾毓|鬲賵賯賾毓_氐丿賯|卮睾賾賱_丕禺鬲亘丕乇丕鬲|卮亘賰丞_毓氐亘賷丞|丿乇賾亘|鬲賳亘兀|丕丨賮馗_賳賲賵匕噩|丨賲賾賱_賳賲賵匕噩|賯丕賲賵爻|賯丕賲賵爻_囟毓|賯丕賲賵爻_噩賱亘|賯丕賲賵爻_賲賮丕鬲賷丨|賲噩賲賵毓丞|胤丕亘賵乇|賲賰丿爻|賰賵賲丞|賯丕卅賲丞_賲乇鬲亘胤丞|卮噩乇丞_亘丨孬|鬲賷丕乇|鬲賷丕乇_賲賳_賳胤丕賯|鬲乇鬲賷亘_爻乇賷毓|鬲乇鬲賷亘_丿賲噩|亘丨孬_孬賳丕卅賷|賲爻丕賮丞_鬲丨乇賷乇|亘丨孬_毓賲賯|亘丨孬_毓乇囟|兀賯氐乇_賲爻丕乇|毓丿丿_賰亘賷乇|賰亘_噩賲毓|賰亘_囟乇亘|賰亘_兀爻|賰亘_賲囟乇賵亘|賰亘_廿賱賶_賳氐|賱賵丨丞|夭乇|丨賯賱|毓賳賵丕賳|賮賯乇丞|丨丕賵賷丞|兀囟賮|兀賳賲丕胤|丕爻鬲賲毓|睾賷賾乇_賳氐)(?![\\u0600-\\u06FF_\\w])"
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.sifr", "match": "(==|!=|<=|>=|&&|\\|\\||\\+|\\-|\\*|\\/|%|<|>|=|!|\\?)" }
      ]
    }
  }
}
